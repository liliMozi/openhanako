{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["desktop/src/react/*"]
    }
  },
  "include": ["desktop/src/**/*.ts", "desktop/src/**/*.tsx"],
  "exclude": ["node_modules", "desktop/dist-renderer"]
}
