{
  "id": "gateway-bridge",
  "name": "Gateway Bridge",
  "version": "1.0.0",
  "description": "与滨面仕上 Gateway 直接通信的原生工具",
  "trust": "full-access",
  "hidden": true,
  "contributes": {
    "configuration": {
      "properties": {
        "gatewayUrl": {
          "type": "string",
          "title": "Gateway WebSocket 地址",
          "description": "滨面 Gateway 的 WebSocket URL",
          "default": "wss://claw.13ehappy.com:18789"
        },
        "gatewayPassword": {
          "type": "string",
          "title": "Gateway 密码",
          "description": "WebSocket auth 密码",
          "default": "Ruijie@123"
        },
        "sessionKey": {
          "type": "string",
          "title": "对话 session key",
          "description": "发送消息的目标会话",
          "default": "agent:main:d_laoshi"
        }
      }
    }
  }
}
